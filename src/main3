// -------- Exit Codes --------
#[repr(i32)]
#[derive(Debug, Clone, Copy)]
pub enum ExitCode {
    Success = 0,
    ServiceStarted = 100,
    TargetAdded = 101,
    TargetRemoved = 102,
    TargetNotFound = 103,
    MacResolutionFailed = 104,
    PermissionDenied = 105,
    InvalidArgument = 106,
    InterfaceNotFound = 107,
    GatewayNotFound = 108,
    InternalError = 109,
    AlreadyExists = 110,
    FlushComplete = 111,
    ScanComplete = 112,
    SaveComplete = 113,
    LoadComplete = 114,
    BanAdded = 115,
    BanRemoved = 116,
}

impl ExitCode {
    pub fn to_string(&self) -> String {
        match self {
            ExitCode::Success => "SUCCESS".to_string(),
            ExitCode::ServiceStarted => "SERVICE_STARTED".to_string(),
            ExitCode::TargetAdded => "TARGET_ADDED".to_string(),
            ExitCode::TargetRemoved => "TARGET_REMOVED".to_string(),
            ExitCode::TargetNotFound => "TARGET_NOT_FOUND".to_string(),
            ExitCode::MacResolutionFailed => "MAC_RESOLUTION_FAILED".to_string(),
            ExitCode::PermissionDenied => "PERMISSION_DENIED".to_string(),
            ExitCode::InvalidArgument => "INVALID_ARGUMENT".to_string(),
            ExitCode::InterfaceNotFound => "INTERFACE_NOT_FOUND".to_string(),
            ExitCode::GatewayNotFound => "GATEWAY_NOT_FOUND".to_string(),
            ExitCode::InternalError => "INTERNAL_ERROR".to_string(),
            ExitCode::AlreadyExists => "ALREADY_EXISTS".to_string(),
            ExitCode::FlushComplete => "FLUSH_COMPLETE".to_string(),
            ExitCode::ScanComplete => "SCAN_COMPLETE".to_string(),
            ExitCode::SaveComplete => "SAVE_COMPLETE".to_string(),
            ExitCode::LoadComplete => "LOAD_COMPLETE".to_string(),
            ExitCode::BanAdded => "BAN_ADDED".to_string(),
            ExitCode::BanRemoved => "BAN_REMOVED".to_string(),
        }
    }
    
    pub fn exit(&self, message: Option<&str>) -> ! {
        if let Some(msg) = message {
            let parts: Vec<&str> = msg.split('|').collect();
            let code = *self as i32;
            let ip = if parts.len() >= 2 && parts[1].parse::<Ipv4Addr>().is_ok() {
                parts[1]
            } else {
                "N/A"
            };
            println!("{}|{}|{}|{}", code, self.to_string(), ip, parts[0]);
        }
        exit(*self as i32);
    }
}

