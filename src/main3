// -------- Statistics --------

struct Stats {
    pub targets: Arc<Mutex<HashMap<Ipv4Addr, TargetStats>>>,
}

#[derive(Debug, Clone)]
struct TargetStats {
    packets_sent: u64,
    packets_received: u64,
    last_poison: Instant,
    first_seen: Instant,
}

impl Stats {
    fn new() -> Self {
        Self {
            targets: Arc::new(Mutex::new(HashMap::new())),
        }
    }

    fn record_send(&self, ip: Ipv4Addr) {
        let mut map = self.targets.lock().unwrap();
        let entry = map.entry(ip).or_insert_with(|| TargetStats {
            packets_sent: 0,
            packets_received: 0,
            last_poison: Instant::now(),
            first_seen: Instant::now(),
        });
        entry.packets_sent += 1;
        entry.last_poison = Instant::now();
    }

    fn get_stats(&self, ip: Ipv4Addr) -> Option<TargetStats> {
        self.targets.lock().unwrap().get(&ip).cloned()
    }

    fn get_all_stats(&self) -> HashMap<Ipv4Addr, TargetStats> {
        self.targets.lock().unwrap().clone()
    }
}

