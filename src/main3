fn save_targets(
    targets: &HashMap<Ipv4Addr, TargetInfo>,
    bans: &Vec<Ipv4Addr>,
    filename: &str,
) -> Result<()> {
    let mut entries = Vec::new();
    for (ip, info) in targets {
        entries.push(TargetEntry {
            ip: ip.to_string(),
            mac: format_mac(&info.mac),
            added_at: info.added_at.elapsed().as_secs(),
            last_seen: current_timestamp(),
            packets_sent: info.packets_sent,
        });
    }
    
    let data = PersistenceData {
        version: 1,
        targets: entries,
        bans: bans.iter().map(|ip| ip.to_string()).collect(),
        created_at: current_timestamp(),
        updated_at: current_timestamp(),
    };
    
    let json = serde_json::to_string_pretty(&data)?;
    std::fs::write(filename, json)?;
    
    eprintln!("[+] Targets saved to {}", filename);
    Ok(())
}

fn load_targets(
    filename: &str,
    iface: &str,
    src_mac: [u8; 6],
    src_ip: Ipv4Addr,
    ifindex: i32,
    timeout: Duration,
    stop: &Arc<AtomicBool>,
) -> Result<(HashMap<Ipv4Addr, TargetInfo>, Vec<Ipv4Addr>)> {
    if !std::path::Path::new(filename).exists() {
        return Ok((HashMap::new(), Vec::new()));
    }
    
    let content = std::fs::read_to_string(filename)?;
    let data: PersistenceData = serde_json::from_str(&content)?;
    
    let mut targets = HashMap::new();
    let mut bans = Vec::new();
    
    // Resolve MACs for loaded targets
    for entry in data.targets {
        if let Ok(ip) = entry.ip.parse::<Ipv4Addr>() {
            // If MAC is stored, use it
            if let Some(mac) = parse_mac(&entry.mac) {
                targets.insert(ip, TargetInfo {
                    ip,
                    mac,
                    added_at: Instant::now(),
                    packets_sent: 0,
                });
                eprintln!("[*] Loaded target {} with MAC {}", ip, entry.mac);
            } else {
                // Try to resolve MAC
                eprintln!("[*] Resolving MAC for loaded target {}...", ip);
                if let Ok(mac) = resolve_mac(iface, src_mac, src_ip, ip, ifindex, timeout, stop) {
                    targets.insert(ip, TargetInfo {
                        ip,
                        mac,
                        added_at: Instant::now(),
                        packets_sent: 0,
                    });
                    eprintln!("[+] Loaded target {} ({})", ip, format_mac(&mac));
                } else {
                    eprintln!("[!] Failed to resolve MAC for loaded target {}", ip);
                }
            }
        }
    }
    
    for ban_ip in data.bans {
        if let Ok(ip) = ban_ip.parse::<Ipv4Addr>() {
            bans.push(ip);
        }
    }
    
    eprintln!("[+] Loaded {} targets from {}", targets.len(), filename);
    Ok((targets, bans))
}

